pipeline {
    agent any

    parameters {
        choice(
            name: 'ACTION',
            choices: ['apply', 'destroy'],
            description: '🔧 Yapılacak işlemi seçin'
        )
        // Buraya ekledik: Artık isim değiştirmek için koda girmene gerek yok!
        string(
            name: 'INSTANCE_NAME',
            defaultValue: 'mydemo-eks-worker-node',
            description: 'EC2 panelinde görünecek Node ismi'
        )
    }

    stages {
        stage('Checkout from Git') {
            steps {
                checkout scm 
            }
        }

        stage('Terraform Init') {
            steps {
                dir('_01_terraform/_03_eks-terraform') {
                    sh 'terraform init --reconfigure'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('_01_terraform/_03_eks-terraform') {
                    // Değişkeni buradan besliyoruz
                    sh "terraform plan -var='instance_name=${params.INSTANCE_NAME}' -out=tfplan"
                }
            }
        }

        stage('Terraform Apply') {
            when { expression { params.ACTION == 'apply' } }
            steps {
                dir('_01_terraform/_03_eks-terraform') {
                    sh 'terraform apply -auto-approve tfplan'
                }
            }
        }

        stage('Terraform Destroy Confirm') {
            when { expression { params.ACTION == 'destroy' } }
            steps {
                input message: "EKS Cluster'ı silmek istediğinizden emin misiniz?", ok: "Evet, Sil"
            }
        }

        stage('Terraform Destroy') {
            when { expression { params.ACTION == 'destroy' } }
            steps {
                dir('_01_terraform/_03_eks-terraform') {
                    sh "terraform destroy -var='instance_name=${params.INSTANCE_NAME}' -auto-approve"
                }
            }
        }
    }
    
    post {
        success {
            echo "✅ İşlem başarıyla tamamlandı!"
        }
        failure {
            echo "❌ Hata oluştu! Lütfen logları ve Access Entry ayarlarını kontrol edin."
        }
    }
}