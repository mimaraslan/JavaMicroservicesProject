pipeline {
    agent any

    parameters {
        choice(
            name: 'ACTION',
            choices: ['apply', 'destroy'],
            description: '🔧 Yapılacak işlemi seçin (Dikkat: destroy tüm EKS yapısını siler!)'
        )
    }

    stages {
        stage('Checkout from Git') {
            steps {
                checkout scm 
            }
        }

        stage('Terraform Init') {
            steps {
                dir('_01_terraform/_03_eks-terraform') {
                    sh 'terraform init --reconfigure'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('_01_terraform/_03_eks-terraform') {
                    // Planı bir dosyaya yazıyoruz
                    sh 'terraform plan -out=tfplan'
                }
            }
        }

        stage('Terraform Apply') {
            when { expression { params.ACTION == 'apply' } }
            steps {
                dir('_01_terraform/_03_eks-terraform') {
                    // Sadece hazırlanan planı uyguluyoruz
                    sh 'terraform apply -auto-approve tfplan'
                }
            }
        }

        stage('Terraform Destroy Confirm') {
            when { expression { params.ACTION == 'destroy' } }
            steps {
                // Silme işlemi öncesi manuel onay (Opsiyonel)
                input message: "EKS Cluster'ı silmek istediğinizden emin misiniz?", ok: "Evet, Sil"
            }
        }

        stage('Terraform Destroy') {
            when { expression { params.ACTION == 'destroy' } }
            steps {
                dir('_01_terraform/_03_eks-terraform') {
                    sh 'terraform destroy -auto-approve'
                }
            }
        }
    }
    
    post {
        always {
            echo "İşlem tamamlandı. Durum: ${currentBuild.result}"
        }
    }
}