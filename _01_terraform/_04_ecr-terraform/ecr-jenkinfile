pipeline {
    agent any

    parameters {
        choice(
            name: 'ACTION',
            choices: ['apply', 'destroy'],
            description: '🔧 Yapılacak işlemi seçin (apply: ECR Repolarını oluşturur, destroy: Tüm repoları siler!)'
        )
    }

    stages {
        stage('Checkout from Git') {
            steps {
                echo 'GitHub repository çekiliyor...'
                checkout scm 
            }
        }

        stage('Terraform Version Check') {
            steps {
                sh 'terraform --version'
            }
        }

        stage('Terraform Init') {
            steps {
                dir('_01_terraform/_04_ecr-terraform') {
                    // Backend yapılandırmasını tazeleyerek başlatıyoruz
                    sh 'terraform init --reconfigure'
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir('_01_terraform/_04_ecr-terraform') {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('_01_terraform/_04_ecr-terraform') {
                    // EKS'de yaptığımız gibi planı bir dosyaya kaydediyoruz
                    // Bu, planlanan ile uygulananın aynı olmasını garanti eder.
                    sh 'terraform plan -out=tfplan_ecr'
                }
            }
        }

        stage('Terraform Apply') {
            when {
                expression { params.ACTION == 'apply' }
            }
            steps {
                dir('_01_terraform/_04_ecr-terraform') {
                    // Hazırlanan plan dosyasını uyguluyoruz
                    sh 'terraform apply -auto-approve tfplan_ecr'
                }
            }
        }

        stage('Terraform Destroy Confirm') {
            when {
                expression { params.ACTION == 'destroy' }
            }
            steps {
                // ECR repolarını silmek tehlikelidir (İmajlar gider), onay alıyoruz.
                input message: "Tüm ECR depolarını ve içindeki imajları silmek istediğinizden emin misiniz?", ok: "Evet, Hepsini Sil"
            }
        }

        stage('Terraform Destroy') {
            when {
                expression { params.ACTION == 'destroy' }
            }
            steps {
                dir('_01_terraform/_04_ecr-terraform') {
                    sh 'terraform destroy -auto-approve'
                }
            }
        }
    }

    post {
        always {
            echo "--------------------------------------------------"
            echo "ECR İşlemi Tamamlandı. Durum: ${currentBuild.result}"
            echo "--------------------------------------------------"
        }
        success {
            echo "✅ ECR altyapısı başarıyla güncellendi."
        }
        failure {
            echo "❌ ECR işlemi sırasında bir hata oluştu. Logları kontrol edin."
        }
    }
}