pipeline {
    agent any

    environment {
        GIT_REPO_NAME = "JavaMicroservicesProject"
        GIT_EMAIL = "mimaraslan@gmail.com"
        GIT_USER_NAME = "mimaraslan"        
        IMAGE_NAME = "apigatewayservice"
        MODULE_DIR = "ApiGatewayService"
        REPO_URL = "405834051687.dkr.ecr.us-east-1.amazonaws.com/apigatewayservice"
        YAML_FILE = "apigatewayservice.yaml"
    }

    stages {
        stage('Cleaning Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
 //               checkout scm
                 git branch: 'master', url: 'https://github.com/mimaraslan/JavaMicroservicesProject.git'
            }
        }

stage("Docker Image Build") {
            steps {
                // dir içinden çıkıyoruz, ana dizinde çalışıyoruz
                sh 'docker system prune -f'
                sh 'docker container prune -f'
                
                // -f ile Dockerfile'ın yerini gösteriyoruz, '.' ile ana dizini bağlam (context) yapıyoruz
                sh 'docker build -t ${IMAGE_NAME} -f ${MODULE_DIR}/Dockerfile .'
            }
        }

        stage("ECR Image Pushing") {
            steps {
                sh '''
                    aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin 405834051687.dkr.ecr.us-east-1.amazonaws.com
                    docker tag ${IMAGE_NAME}:latest ${REPO_URL}:${BUILD_NUMBER}
                    docker push ${REPO_URL}:${BUILD_NUMBER}
                '''
            }
        }

 stage('Update Deployment file') {
            steps {
                dir('_01_terraform/_06_kubernetes-files') {
                    withCredentials([string(credentialsId: 'MyTokenGitHub', variable: 'git_token')]) {
                        sh '''
                            git config user.email "${GIT_EMAIL}"
                            git config user.name "${GIT_USER_NAME}"
                            echo $BUILD_NUMBER
                            sed -i "s#image:.*#image: ${REPO_URL}:$BUILD_NUMBER#g" ${YAML_FILE}
                            git add .
                            git commit -m "Update ${IMAGE_NAME} Image to version ${BUILD_NUMBER}"
                            git push https://${git_token}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:master
                        '''
                    } // withCredentials kapandı
                } // dir kapandı
            } // steps kapandı
        } // stage kapandı
    } // stages kapandı
} // pipeline kapandı